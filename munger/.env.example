# Copy to .env and fill in values from your Pigsty install.
# Pigsty admin password: docker exec pigsty grep pg_admin_password /root/pigsty/pigsty.yml

# Postgres host: use "pigsty" when Munger joins the Pigsty Docker network (default in compose).
# Use "host.docker.internal" only if Postgres is exposed on the host without the shared network.
MUNGER_POSTGRES_HOST=pigsty

# DBA connection for one-shot db bootstrap (munger-db-init)
MUNGER_POSTGRES_ADMIN_URL=postgresql://dbuser_dba:YOUR_PG_ADMIN_PASSWORD@${MUNGER_POSTGRES_HOST}:5432/postgres

# App role/database created by bootstrap
MUNGER_POSTGRES_APP_USER=munger_app
MUNGER_DB_PASSWORD=Munger.App.2026
MUNGER_POSTGRES_APP_DB=munger

# LLM (required for ingest) — OpenRouter stack
OPENROUTER_API_KEY=
LLM_DEFAULT_PROVIDER=openrouter
LLM_DEFAULT_MODEL=deepseek/deepseek-v4-flash
LLM_EMBEDDING_MODEL=qwen/qwen3-embedding-8b
LLM_EMBEDDING_DIMENSIONS=768

# Vector store backend (SP1.2): pgvector (default — embeddings stay in Postgres) | lancedb
# LANCEDB_URI is only used when VECTOR_BACKEND=lancedb (local dataset directory).
VECTOR_BACKEND=pgvector
LANCEDB_URI=./data/lancedb

# Ingest pipeline
# Extraction window: extract entities over K consecutive chunks per LLM call
# (1 = legacy per-chunk; 2-3 recommended for dense papers — fewer calls, less entity fragmentation)
INGEST_EXTRACTION_WINDOW_CHUNKS=1
# Co-mention diet: minimum shared chunks for a co_mention edge (default 2; set to 1 for legacy ≥1 behaviour)
INGEST_COMENTION_MIN_CHUNKS=2
# Wiki generation gate: skip entity wiki pages for entities with fewer than this many mentions
# (default 2; set to 1 to generate pages for all entities including singletons)
INGEST_WIKI_MIN_MENTIONS=2

# LangSmith (ingest observability — traces graph nodes + LLM calls)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=munger-ingest
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=munger-ingest
# LANGCHAIN_CALLBACKS_BACKGROUND=false

# OpenTelemetry (SP6). In docker compose this is preset to the munger-lgtm container.
# For bare-metal dev, opt in with: OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Unset = telemetry completely off (zero overhead).
